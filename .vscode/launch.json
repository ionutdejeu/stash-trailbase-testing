{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Stash Serve",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/cli",
      "args": [
        "serve"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "STASH_OPENAI_BASE_URL": "https://api.openai.com/v1",
        "STASH_EMBEDDING_MODEL": "text-embedding-3-small",
        "STASH_REASONER_MODEL": "gpt-4.1-mini",
        "STASH_VECTOR_DIM": "1536"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Run Stash Env",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/cli",
      "args": [
        "env"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "STASH_OPENAI_BASE_URL": "https://api.openai.com/v1",
        "STASH_EMBEDDING_MODEL": "text-embedding-3-small",
        "STASH_REASONER_MODEL": "gpt-4.1-mini",
        "STASH_VECTOR_DIM": "1536"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}